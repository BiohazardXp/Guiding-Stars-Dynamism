{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/name-role-value": [
      "default",
      {
        "button-name": "off"
      }
    ],
    "axe/forms": "off",
    "css-prefix-order": "off",
    "compat-api/css": [
      "off",
      {
        "ignore": [
          "scrollbar-width"
        ]
      }
    ],
    "no-inline-styles": "off",
    "axe/text-alternatives": "off"
  }
}